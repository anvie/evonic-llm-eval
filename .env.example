# Evonic LLM Evaluator - Environment Variables
# Copy this file to .env and fill in your values

# LLM Configuration (OpenAI-compatible endpoint)
# For OpenRouter: https://openrouter.ai/api/v1
# For local LLM (llama.cpp, Ollama, etc): http://localhost:8080/v1
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=moonshotai/kimi-k2-thinking
LLM_TIMEOUT=120
LLM_MAX_TOKENS=32768      # Max output tokens requested per call
LLM_CONTEXT_LENGTH=0      # Set to model's max_model_len to auto-cap output tokens (e.g. 16384). 0 = disabled
LLM_PROMPT_BUFFER=2048    # Tokens reserved for input when LLM_CONTEXT_LENGTH is set

# Two-Pass Extraction (PASS1: generate answer, PASS2: extract final answer)
TWO_PASS_ENABLED=1
TWO_PASS_TEMPERATURE=0.0

# Anthropic API (for improver module - analysis & training data generation)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Flask Configuration
SECRET_KEY=your-secret-key-here
HOST=0.0.0.0
PORT=8080
DEBUG=1

# Real-time Log Verbosity (set to 1 to include full content in live logs)
LOG_FULL_THINKING=0
LOG_FULL_RESPONSE=0
